{
  "name": "jdtorrent",
  "private": true,
  "version": "0.5.2",
  "main": "dist-electron/main.js",
  "author": {
    "name": "=JD=",
    "email": "jd@jdtorrent.app"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron dist-electron/main.js --no-sandbox",
    "build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "build:win": "vite build && tsc -p electron/tsconfig.json && electron-builder --win --publish never",
    "build:linux": "vite build && tsc -p electron/tsconfig.json && electron-builder --linux --publish never",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.jdtorrent.app",
    "productName": "JDTorrent",
    "publish": {
      "provider": "github",
      "owner": "jorgedjr21",
      "repo": "jdtorrent"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "bulma": "^1.0.4",
    "electron-updater": "^6.8.3",
    "vue": "^3.5.25",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/webtorrent": "^0.110.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5",
    "wait-on": "^9.0.4"
  }
}
